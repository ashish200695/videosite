// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  password              String?
  name                  String?
  role                  UserRole  @default(CONTRIBUTOR)
  bio                   String?
  profileImage          String?
  
  // Contributor specific fields
  bankAccountNumber     String?
  bankIfscCode          String?
  upiId                 String?
  paypalEmail           String?
  revenueShare          Float     @default(50.0)
  totalEarnings         Float     @default(0)
  totalPaid             Float     @default(0)
  
  // Account status
  isActive              Boolean   @default(true)
  isSuspended           Boolean   @default(false)
  suspensionReason      String?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations
  submissions           Submission[]
  payouts               Payout[]
  
  @@index([email])
  @@index([role])
}

enum UserRole {
  ADMIN
  CONTRIBUTOR
}

model Story {
  id                    String    @id @default(cuid())
  title                 String
  description           String    @db.Text
  category              String
  tags                  String[]  @default([])
  thumbnailUrl          String?
  dailymotionVideoId    String    @unique
  dailymotionEmbedCode  String?
  
  viewCount             Int       @default(0)
  estimatedRevenue      Float     @default(0)
  lastRevenueSync       DateTime?
  
  contributor           User?     @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  contributorId         String?
  
  isPublished           Boolean   @default(false)
  publishedAt           DateTime?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations
  submission            Submission?
  revenueRecords        RevenueRecord[]
  
  @@index([category])
  @@index([contributorId])
  @@index([isPublished])
}

model Submission {
  id                    String    @id @default(cuid())
  title                 String
  description           String    @db.Text
  category              String
  tags                  String[]  @default([])
  language              String    @default("Hindi")
  
  // Uploaded files (temporary storage)
  videoFileUrl          String?   @db.Text
  thumbnailUrl          String?   @db.Text
  originalDailymotionUrl String?  @db.Text
  
  status                SubmissionStatus @default(PENDING)
  rejectionReason       String?
  
  contributor           User      @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  contributorId         String
  
  story                 Story?    @relation(fields: [storyId], references: [id])
  storyId               String?   @unique
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  reviewedAt            DateTime?
  
  @@index([status])
  @@index([contributorId])
  @@index([createdAt])
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
}

model RevenueRecord {
  id                    String    @id @default(cuid())
  story                 Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  storyId               String
  
  viewCount             Int
  estimatedRevenue      Float
  contributorEarnings   Float
  platformEarnings      Float
  revenueShare          Float
  
  syncedFromDailymotion DateTime?
  recordDate            DateTime  @default(now())
  
  @@index([storyId])
  @@index([recordDate])
}

model Payout {
  id                    String    @id @default(cuid())
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String
  
  amount                Float
  status                PayoutStatus @default(PENDING)
  payoutMethod          PayoutMethod
  
  bankAccountNumber     String?
  upiId                 String?
  paypalEmail           String?
  
  transactionId         String?
  processedAt           DateTime?
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
}

enum PayoutMethod {
  BANK_TRANSFER
  UPI
  PAYPAL
}

model ContentPolicy {
  id                    String    @id @default(cuid())
  title                 String
  content               String    @db.Text
  version               Int       @default(1)
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  @@index([title])
}

model Analytics {
  id                    String    @id @default(cuid())
  totalViews            Int       @default(0)
  totalRevenue          Float     @default(0)
  totalStories          Int       @default(0)
  totalContributors     Int       @default(0)
  totalPayoutsProcessed Float     @default(0)
  
  recordDate            DateTime  @default(now())
  
  @@index([recordDate])
}
